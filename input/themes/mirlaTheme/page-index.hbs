{{! page-index.hbs - Microfrontend injection template for the index }}
{{> head}}
{{> navbar}}

<main class="page">
  <article>
    <div id="post-entry">
      {{{text}}}
    </div>

    {{!-- 1. The Mounting Point --}}
    <div id="mirla-collection-app"></div>

    {{!-- 2. Pass the dynamic domain to Svelte --}}
    <script>
      window.MIRLA_CONTEXT = {
        siteDomain: "{{@website.baseUrl}}",
        mediaUrl: "{{@website.mediaFilesUrl}}",
        i18n: {
          searchPlaceholder: "{{translate 'mirla.searchPlaceholder' fallback='Search...'}}",
          resultsFound: "{{translate 'mirla.resultsFound' fallback='results found'}}",
          loading: "{{translate 'mirla.loading' fallback='Loading...'}}",
          all: "{{translate 'mirla.all' fallback='All'}}"
        }
      };
    </script>

    {{!-- 3. Load the Data Payload (No fetch required) --}}
    <script defer src="{{@website.mediaFilesUrl}}collection/collection-data.js"></script>

    {{!-- 4. Load the compiled Svelte App --}}
    <script defer src="{{js "collection-app.js"}}"></script>

  </article>
</main>

{{> footer}}